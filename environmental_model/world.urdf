    <child link="block_basin_left_wall"/>
    <origin xyz="-0.1835 0 0.09" rpy="0 0 0"/>
  </joint>

  <joint name="basin_right_joint" type="fixed">
    <parent link="block_basin_bottom"/>
    <child link="block_basin_right_wall"/>
    <origin xyz="0.1835 0 0.09" rpy="0 0 0"/>
  </joint>

  <!-- ===== UR10 with shovel ===== -->
  <link name="base_jizuo_base_ur10_with_dizuo">
