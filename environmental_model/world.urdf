<?xml version="1.0" encoding="utf-8"?>
<robot name="world_scene">
  <!-- Combined scene for later pose tuning.
       Adjust only the two frame joints below to move each object as a whole. -->

  <material name="block_gray">
    <color rgba="0.6 0.6 0.6 0.8"/>
  </material>
  <material name="basin_blue">
    <color rgba="0.2 0.4 0.8 0.7"/>
  </material>
  <material name="mat_sensor_shovel">
    <color rgba="0.79216078 0.81961176 0.92941569 1.00000000"/>
  </material>
  <material name="mat_shovel_tcp">
    <color rgba="1.00000000 1.00000000 1.00000000 1.00000000"/>
  </material>
  <material name="mat_base_jizuo">
    <color rgba="1.00000000 1.00000000 1.00000000 1.00000000"/>
  </material>
  <material name="mat_base_ur10_with_dizuo">
    <color rgba="1.00000000 1.00000000 1.00000000 1.00000000"/>
  </material>
  <material name="SWMaterial-0">
    <color rgba="0.22353333 0.22353333 0.22353333 1.00000000"/>
  </material>
  <material name="SWMaterial-1">
    <color rgba="0.39216078 0.54118039 0.63921961 1.00000000"/>
  </material>
  <material name="SWMaterial-2">
    <color rgba="0.46274902 0.46274902 0.46274902 1.00000000"/>
  </material>
  <material name="SWMaterial-3">
    <color rgba="0.65490588 0.65490588 0.65490588 1.00000000"/>
  </material>
  <material name="SWMaterial-4">
    <color rgba="0.07843529 0.07843529 0.07843529 1.00000000"/>
  </material>
  <material name="SWMaterial-0_001">
    <color rgba="0.22353333 0.22353333 0.22353333 1.00000000"/>
  </material>
  <material name="SWMaterial-1_001">
    <color rgba="0.39216078 0.54118039 0.63921961 1.00000000"/>
  </material>
  <material name="SWMaterial-2_001">
    <color rgba="0.37255294 0.37255294 0.37255294 1.00000000"/>
  </material>
  <material name="SWMaterial-0_002">
    <color rgba="0.22353333 0.22353333 0.22353333 1.00000000"/>
  </material>
  <material name="SWMaterial-1_002">
    <color rgba="0.39216078 0.54118039 0.63921961 1.00000000"/>
  </material>
  <material name="SWMaterial-2_002">
    <color rgba="0.46274902 0.46274902 0.46274902 1.00000000"/>
  </material>
  <material name="SWMaterial-2_003">
    <color rgba="0.46274902 0.46274902 0.46274902 1.00000000"/>
  </material>

  <link name="world"/>
  <link name="block_with_basin_frame"/>
  <link name="base_jizuo">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/base_link_world_jizuo.STL" />
      </geometry>
      <material name="mat_base_jizuo"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/base_link_world_jizuo.STL" />
      </geometry>
    </collision>
    <inertial>
      <origin xyz="-1.8696 -0.046752 0.24794" rpy="0 0 0" />
      <mass value="1499.1" />
      <inertia ixx="1126.8" ixy="-0.036857" ixz="0.0017432" iyy="2608.5" iyz="-18.236" izz="3614.6" />
    </inertial>
  </link>

  <!-- Edit this joint to move the block + basin as one object. -->
  <joint name="world_to_block_with_basin_frame" type="fixed">
    <parent link="base_jizuo"/>
    <child link="block_with_basin_frame"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Full assembly root from assembly.urdf.xacro. -->
  <joint name="world_to_base_jizuo" type="fixed">
    <parent link="world"/>
    <child link="base_jizuo"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ===== Block with basin ===== -->
  <link name="block_basin_base_link"/>

  <link name="block_basin_block">
    <visual>
      <geometry>
        <box size="1.0 1.0 0.25"/>
      </geometry>
      <material name="block_gray"/>
    </visual>
    <collision>
      <geometry>
        <box size="1.0 1.0 0.25"/>
      </geometry>
    </collision>
  </link>

  <link name="block_basin_bottom">
    <visual>
      <geometry>
        <box size="0.37 0.50 0.003"/>
      </geometry>
      <material name="basin_blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.37 0.50 0.003"/>
      </geometry>
    </collision>
  </link>

  <link name="block_basin_front_wall">
    <visual>
      <geometry>
        <box size="0.37 0.003 0.18"/>
      </geometry>
      <material name="basin_blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.37 0.003 0.18"/>
      </geometry>
    </collision>
  </link>

  <link name="block_basin_back_wall">
    <visual>
      <geometry>
        <box size="0.37 0.003 0.18"/>
      </geometry>
      <material name="basin_blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.37 0.003 0.18"/>
      </geometry>
    </collision>
  </link>

  <link name="block_basin_left_wall">
    <visual>
      <geometry>
        <box size="0.003 0.494 0.18"/>
      </geometry>
      <material name="basin_blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.003 0.494 0.18"/>
      </geometry>
    </collision>
  </link>

  <link name="block_basin_right_wall">
    <visual>
      <geometry>
        <box size="0.003 0.494 0.18"/>
      </geometry>
      <material name="basin_blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.003 0.494 0.18"/>
      </geometry>
    </collision>
  </link>

  <joint name="block_frame_to_base" type="fixed">
    <parent link="block_with_basin_frame"/>
    <child link="block_basin_base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="block_joint" type="fixed">
    <parent link="block_basin_base_link"/>
    <child link="block_basin_block"/>
    <origin xyz="0 0 0.125" rpy="0 0 0"/>
  </joint>

  <joint name="basin_base_joint" type="fixed">
    <parent link="block_basin_base_link"/>
    <child link="block_basin_bottom"/>
    <origin xyz="-0.135 0 0.25" rpy="0 0 0"/>
  </joint>

  <joint name="basin_front_joint" type="fixed">
    <parent link="block_basin_bottom"/>
    <child link="block_basin_front_wall"/>
    <origin xyz="0 0.2485 0.09" rpy="0 0 0"/>
  </joint>

  <joint name="basin_back_joint" type="fixed">
    <parent link="block_basin_bottom"/>
    <child link="block_basin_back_wall"/>
