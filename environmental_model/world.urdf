  <joint name="base_jizuo_square_place" type="fixed">
    <parent link="base_jizuo"/>
    <child link="base_jizuo_base_ur10_with_dizuo"/>
    <origin xyz="-0.78172 -0.025653 1.1638" rpy="3.1416 0 -1.5708"/>
  </joint>

  <joint name="base_jizuo_to_ur10" type="fixed">
    <parent link="base_jizuo_base_ur10_with_dizuo"/>
    <child link="ur10"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="sensor_shovel_tcp_fixed" type="fixed">
