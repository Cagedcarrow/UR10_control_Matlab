<?xml version="1.0" encoding="utf-8"?>
<robot name="block_with_basin">
  <!-- Assembly: solid block (100×100×25 cm) on ground,
       rectangular basin (37×50×18 cm, 3mm wall) placed on top -->

  <!-- Materials -->
  <material name="block_gray">
    <color rgba="0.6 0.6 0.6 0.8"/>
  </material>
  <material name="basin_blue">
    <color rgba="0.2 0.4 0.8 0.7"/>
  </material>

  <!-- Virtual root link -->
  <link name="base_link"/>

  <!-- ===== Solid Block (100×100×25 cm, origin at center) ===== -->
  <link name="block">
    <visual>
      <geometry>
        <box size="1.0 1.0 0.25"/>
      </geometry>
      <material name="block_gray"/>
    </visual>
    <collision>
      <geometry>
        <box size="1.0 1.0 0.25"/>
      </geometry>
    </collision>
  </link>

  <!-- ===== Rectangular Basin (37×50×18 cm, 3mm wall, origin at bottom center) ===== -->
  <!-- Bottom plate: 37×50×0.3 cm -->
  <link name="basin_bottom">
    <visual>
      <geometry>
        <box size="0.37 0.50 0.003"/>
      </geometry>
      <material name="basin_blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.37 0.50 0.003"/>
      </geometry>
    </collision>
  </link>

  <!-- Front wall (Y+): 37×0.3×18 cm -->
  <link name="basin_front_wall">
    <visual>
      <geometry>
        <box size="0.37 0.003 0.18"/>
      </geometry>
      <material name="basin_blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.37 0.003 0.18"/>
      </geometry>
    </collision>
  </link>

  <!-- Back wall (Y-): 37×0.3×18 cm -->
  <link name="basin_back_wall">
    <visual>
      <geometry>
        <box size="0.37 0.003 0.18"/>
      </geometry>
      <material name="basin_blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.37 0.003 0.18"/>
      </geometry>
    </collision>
  </link>

  <!-- Left wall (X-): 0.3×49.4×18 cm -->
  <link name="basin_left_wall">
    <visual>
      <geometry>
        <box size="0.003 0.494 0.18"/>
      </geometry>
      <material name="basin_blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.003 0.494 0.18"/>
      </geometry>
    </collision>
  </link>

  <!-- Right wall (X+): 0.3×49.4×18 cm -->
  <link name="basin_right_wall">
    <visual>
      <geometry>
        <box size="0.003 0.494 0.18"/>
      </geometry>
      <material name="basin_blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.003 0.494 0.18"/>
      </geometry>
    </collision>
  </link>

  <!-- ===== Joints ===== -->

  <!-- Block placed on ground: bottom at Z=0, center at Z=0.125 -->
  <joint name="block_joint" type="fixed">
    <parent link="base_link"/>
    <child link="block"/>
    <origin xyz="0 0 0.125" rpy="0 0 0"/>
  </joint>

  <!-- Basin placed on top of block:
       Basin 50cm edge centered in Y (25cm from each block edge).
       Basin X edge 45cm from +X block edge.
       Basin bottom on block top surface (Z=0.25m). -->
  <joint name="basin_base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="basin_bottom"/>
    <origin xyz="-0.135 0 0.25" rpy="0 0 0"/>
  </joint>

  <!-- Basin wall joints (relative to basin bottom) -->

  <!-- Front wall (Y+) -->
  <joint name="basin_front_joint" type="fixed">
    <parent link="basin_bottom"/>
    <child link="basin_front_wall"/>
    <origin xyz="0 0.2485 0.09" rpy="0 0 0"/>
  </joint>

  <!-- Back wall (Y-) -->
  <joint name="basin_back_joint" type="fixed">
    <parent link="basin_bottom"/>
    <child link="basin_back_wall"/>
    <origin xyz="0 -0.2485 0.09" rpy="0 0 0"/>
  </joint>

  <!-- Left wall (X-) -->
  <joint name="basin_left_joint" type="fixed">
    <parent link="basin_bottom"/>
    <child link="basin_left_wall"/>
    <origin xyz="-0.1835 0 0.09" rpy="0 0 0"/>
  </joint>

  <!-- Right wall (X+) -->
  <joint name="basin_right_joint" type="fixed">
    <parent link="basin_bottom"/>
    <child link="basin_right_wall"/>
    <origin xyz="0.1835 0 0.09" rpy="0 0 0"/>
  </joint>

</robot>
